{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/trdgl/campaign_shard_index.schema.json",
  "title": "TrDGL-FuzzVn multi-seed benchmark shard index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_label", "benchmark_id", "shards"],
  "properties": {
    "schema_version": {"const": "trdgl_campaign_shard_index_v1"},
    "evidence_label": {"enum": ["validation_only", "campaign"]},
    "benchmark_id": {"const": "trdgl_pytorch_120_v1"},
    "shards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["generation_seed", "run_signature", "events_path", "run_manifest_path", "executed_notebook_path"],
        "properties": {
          "generation_seed": {"type": "integer"},
          "run_signature": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "events_path": {"type": "string", "minLength": 1},
          "run_manifest_path": {"type": "string", "minLength": 1},
          "executed_notebook_path": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
